{
  "name": "js-minify-compiler",
  "displayName": "JS Minify Compiler",
  "description": "Minifies JavaScript files and outputs .min.js files to a configurable directory.",
  "version": "1.0.5",
  "publisher": "MMLTECH",
  "homepage": "https://streamrsc.com",
  "icon": "images/icon.png",
  "galleryBanner": {
    "color": "#f7df1e",
    "theme": "dark"
  },
  "pricing": "Free",
  "sponsor": {
    "url": "https://paypal.me/mmltools"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/mmlTools/js-minify-compiler"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other",
    "Formatters"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onCommand:jsMinifyCompiler.minifyCurrentFile",
    "onCommand:jsMinifyCompiler.minifyWorkspace"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "jsMinifyCompiler.minifyCurrentFile",
        "title": "JS Minify Compiler: Minify Current File"
      },
      {
        "command": "jsMinifyCompiler.minifyWorkspace",
        "title": "JS Minify Compiler: Minify Workspace"
      }
    ],
    "configuration": {
      "title": "JS Minify Compiler",
      "properties": {
        "jsMinifyCompiler.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable JS Minify Compiler."
        },
        "jsMinifyCompiler.minifyOnSave": {
          "type": "boolean",
          "default": true,
          "description": "Automatically minify JavaScript files when they are saved."
        },
        "jsMinifyCompiler.outputDirectory": {
          "type": "string",
          "default": "dist/js",
          "description": "Directory where minified JavaScript files are saved. Relative paths are resolved from the workspace root. Files are written directly into this folder."
        },
        "jsMinifyCompiler.include": {
          "type": "string",
          "default": "**/*.js",
          "description": "Glob pattern for JavaScript files to minify when running workspace minification."
        },
        "jsMinifyCompiler.exclude": {
          "type": "array",
          "default": [
            "**/*.min.js",
            "**/node_modules/**",
            "**/dist/**",
            "**/vendor/**"
          ],
          "items": {
            "type": "string"
          },
          "description": "Glob patterns excluded from minification."
        },
        "jsMinifyCompiler.mangle": {
          "type": "boolean",
          "default": true,
          "description": "Enable variable and function name mangling."
        },
        "jsMinifyCompiler.compress": {
          "type": "boolean",
          "default": true,
          "description": "Enable code compression."
        },
        "jsMinifyCompiler.sourceMap": {
          "type": "boolean",
          "default": false,
          "description": "Generate source maps."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package"
  },
  "dependencies": {
    "terser": "^5.46.2"
  },
  "devDependencies": {
    "@types/node": "^20.19.39",
    "@types/vscode": "1.90.0",
    "typescript": "^5.0.0",
    "vsce": "^2.15.0"
  }
}